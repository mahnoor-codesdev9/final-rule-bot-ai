APP_NAME=RuleBot AI
APP_VERSION=2.1.0
APP_ENV=development
DEBUG=false

CHAT_HISTORY_PATH=chatbot/data/chat_history.json
MAX_MESSAGE_LENGTH=4000
DEFAULT_CHAT_MODE=rule
AI_REQUEST_TIMEOUT=30
AI_RETRY_LIMIT=2

# Comma-separated origins. Leave empty for same-origin deployments.
CORS_ORIGINS=

# Optional AI providers. RuleBot automatically falls back to rule mode when
# these keys are missing or provider calls fail.
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
